<!DOCTYPE html>
<html lang="pa">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KH90 AI Pro - Official Store</title>
    <style>
        :root { --primary: #f55036; --bg: #0d0d0d; --card: #1a1a1c; --text: #e0e0e0; }
        
        body { 
            background: var(--bg); 
            color: var(--text); 
            font-family: 'Segoe UI', Roboto, sans-serif; 
            margin: 0; 
            display: flex; 
            flex-direction: column; 
            height: 100vh; 
            overflow: hidden;
        }

        /* Top Header - TV Style */
        header { 
            padding: 20px 40px; 
            background: linear-gradient(to bottom, #1a1a1c, #0d0d0d);
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            border-bottom: 1px solid #333;
        }

        .brand { display: flex; align-items: center; gap: 20px; }
        
        /* ਤੁਹਾਡਾ ਦਿੱਤਾ ਹੋਇਆ ਲੋਗੋ ਲਿੰਕ */
        .logo-img { 
            width: 80px; 
            height: 80px; 
            border-radius: 50%; 
            border: 3px solid var(--primary); 
            box-shadow: 0 0 15px rgba(245, 80, 54, 0.5);
            object-fit: cover;
        }

        .logo-text { font-weight: bold; color: white; font-size: 32px; letter-spacing: 1px; }
        .version { color: #666; font-size: 14px; margin-left: 10px; }

        .download-btn {
            background: var(--primary);
            color: white;
            text-decoration: none;
            padding: 15px 35px;
            border-radius: 50px;
            font-weight: bold;
            font-size: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 10px 20px rgba(245, 80, 54, 0.4);
            transition: 0.3s;
        }
        .download-btn:hover { transform: scale(1.05); background: #ff6b54; }

        /* Chat Window - Center Area */
        #chat-window { 
            flex: 1; 
            overflow-y: auto; 
            padding: 40px; 
            display: flex; 
            flex-direction: column; 
            gap: 20px;
            background: radial-gradient(circle at 80% 20%, #1a1a1c 0%, #0d0d0d 100%);
        }

        .msg { 
            max-width: 70%; 
            padding: 20px 30px; 
            border-radius: 25px; 
            font-size: 18px; 
            line-height: 1.6;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        .ai { 
            align-self: flex-start; 
            background: rgba(42, 42, 46, 0.8); 
            border: 1px solid #333; 
            border-bottom-left-radius: 5px;
            color: #fff;
        }

        .user { 
            align-self: flex-end; 
            background: var(--primary); 
            color: white; 
            border-bottom-right-radius: 5px;
        }

        /* Bottom Control Bar */
        .input-area { 
            padding: 30px 40px; 
            background: #111; 
            display: flex; 
            align-items: center; 
            gap: 15px;
            border-top: 1px solid #222;
        }

        input { 
            flex: 1; 
            padding: 18px 30px; 
            border-radius: 50px; 
            border: 1px solid #444; 
            background: #000; 
            color: white; 
            outline: none; 
            font-size: 18px;
        }

        .ctrl-btn { 
            width: 60px; 
            height: 60px; 
            border-radius: 50%; 
            border: none; 
            cursor: pointer; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 24px;
            transition: 0.3s;
        }

        .mic-btn { background: #222; color: var(--primary); border: 1px solid #444; }
        .active-mic { background: var(--primary); color: white; animation: pulse 1.5s infinite; }
        .send-btn { background: var(--primary); color: white; }

        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.1); } 100% { transform: scale(1); } }
    </style>
</head>
<body>

    <header>
        <div class="brand">
            <img src="https://raw.githubusercontent.com/khushwinders701-maker/Kh90-ai/main/Logo.png" class="logo-img" alt="KH90 Logo">
            <div class="logo-text">kh90 ai <span class="version">v1.0.2</span></div>
        </div>
        <a href="kh90 ai.apk" download class="download-btn">📥 Download APK Pro</a>
    </header>

    <div id="chat-window">
        <div class="msg ai">ਸਤਿ ਸ਼੍ਰੀ ਅਕਾਲ! ਮੈਂ <b>KH90 AI Pro</b> ਹਾਂ। ਤੁਸੀਂ ਮੇਰੇ ਨਾਲ ਗੱਲ ਕਰ ਸਕਦੇ ਹੋ ਜਾਂ ਉੱਪਰ ਦਿੱਤੇ ਬਟਨ ਤੋਂ ਮੇਰੀ ਐਂਡਰਾਇਡ ਐਪ ਡਾਊਨਲੋਡ ਕਰ ਸਕਦੇ ਹੋ।</div>
    </div>

    <div class="input-area">
        <button class="ctrl-btn mic-btn" id="micBtn" onclick="startListening()">🎤</button>
        <input type="text" id="userInput" placeholder="ਕੁਝ ਪੁੱਛੋ ਜਾਂ 'Open YouTube' ਬੋਲੋ..." onkeypress="if(event.key==='Enter') sendChat()">
        <button class="ctrl-btn send-btn" onclick="sendChat()">➔</button>
    </div>

    <script>
        const API_KEY = "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";
        const chatWindow = document.getElementById('chat-window');
        const userInput = document.getElementById('userInput');
        const micBtn = document.getElementById('micBtn');

        const recognition = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
        
        function startListening() {
            recognition.lang = 'pa-IN';
            recognition.start();
            micBtn.classList.add('active-mic');
        }

        recognition.onresult = (event) => {
            userInput.value = event.results[0][0].transcript;
            micBtn.classList.remove('active-mic');
            sendChat();
        };

        async function sendChat() {
            const text = userInput.value.trim();
            if (!text) return;

            addMessage(text, 'user');
            const lowerText = text.toLowerCase();
            userInput.value = "";

            // App opening Logic
            if (lowerText.includes("youtube") || lowerText.includes("ਯੂਟਿਊਬ")) {
                addMessage("YouTube ਖੋਲ੍ਹ ਰਿਹਾ ਹਾਂ...", 'ai');
                window.location.href = "intent://www.youtube.com/#Intent;scheme=http;package=com.google.android.youtube;end";
                return;
            }

            try {
                const response = await fetch("https://api.groq.com/openai/v1/chat/completions", {
                    method: "POST",
                    headers: { "Authorization": `Bearer ${API_KEY}`, "Content-Type": "application/json" },
                    body: JSON.stringify({
                        model: "llama-3.3-70b-versatile",
                        messages: [{ role: "user", content: text }]
                    })
                });
                const data = await response.json();
                addMessage(data.choices[0].message.content, 'ai');
            } catch (e) {
                addMessage("ਕੁਝ ਗਲਤ ਹੋਇਆ! ਨੈੱਟਵਰਕ ਚੈੱਕ ਕਰੋ।", 'ai');
            }
        }

        function addMessage(text, sender) {
            const div = document.createElement('div');
            div.className = `msg ${sender}`;
            div.innerHTML = text.replace(/\n/g, '<br>');
            chatWindow.appendChild(div);
            chatWindow.scrollTop = chatWindow.scrollHeight;
        }
    </script>
</body>
</html>
